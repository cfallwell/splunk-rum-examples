{
  "name": "@cfallwell/rumbootstrap",
  "version": "1.0.2",
  "description": "v1.0.2: Clarified in the root README that the RUM bootstrap should load first in every supported delivery model. (+2 more updates in CHANGELOG.md)",
  "changelog": "CHANGELOG.md",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "sync:description": "node scripts/sync-package-description.mjs",
    "prebuild": "node ../scripts/generate-rum-embeds.mjs && npm run sync:description",
    "build": "tsc -p tsconfig.json",
    "signalfx:update": "node ../scripts/update-signalfx-scripts.mjs",
    "release:set-version": "node ../scripts/set-release-version.mjs",
    "version": "npm run sync:description",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  },
  "license": "MIT"
}
